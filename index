<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Masjid Digital Display</title>
  
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  
  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    
    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 20px rgba(5,150,105,0.3); }
      50% { box-shadow: 0 0 30px rgba(5,150,105,0.5); }
    }
    .pulse-glow { animation: pulseGlow 3s ease-in-out infinite; }
    
    @keyframes fadeUp { 
      from { opacity:0; transform:translateY(12px); } 
      to { opacity:1; transform:translateY(0); } 
    }
    .fade-up { animation: fadeUp 0.5s ease-out forwards; opacity:0; }
    
    .scrollbar-thin::-webkit-scrollbar { height: 6px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
  </style>
</head>

<body class="bg-gray-50 text-gray-800 min-h-screen">
  
  <!-- HEADER -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white text-xl">
          🕌
        </div>
        <div>
          <h1 id="masjidName" class="text-lg font-bold">Masjid Al-Ikhlas</h1>
          <p id="currentDate" class="text-xs text-gray-500"></p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button id="adminBtn" class="w-9 h-9 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center" title="Admin Mode">
          <i data-lucide="lock" class="w-4 h-4"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="max-w-5xl mx-auto px-4 py-6 space-y-6">
    
    <!-- HERO: Countdown -->
    <section class="rounded-2xl bg-gradient-to-br from-emerald-600 to-emerald-900 p-8 text-white text-center pulse-glow fade-up">
      <p id="heroDate" class="text-emerald-200 text-sm mb-2"></p>
      <p id="clockDisplay" class="text-3xl font-bold mb-4"></p>
      <p class="text-emerald-200 text-xs uppercase tracking-wider mb-1">Menuju</p>
      <p id="nextPrayer" class="text-4xl font-extrabold mb-2">—</p>
      <p id="countdownDisplay" class="text-6xl font-extrabold"></p>
    </section>

    <!-- JADWAL SHALAT -->
    <section class="fade-up" style="animation-delay:0.2s">
      <h2 class="text-sm font-bold uppercase text-gray-400 mb-3 flex items-center gap-2">
        <i data-lucide="clock" class="w-4 h-4"></i> Jadwal Shalat Hari Ini
      </h2>
      <div id="prayerGrid" class="grid grid-cols-5 gap-2"></div>
    </section>

    <!-- TAB: JADWAL KEGIATAN -->
    <section class="fade-up" style="animation-delay:0.3s">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-bold uppercase text-gray-400 flex items-center gap-2">
          <i data-lucide="calendar" class="w-4 h-4"></i> Jadwal Kegiatan
        </h2>
        <button id="btnAddJadwal" class="bg-emerald-600 text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-emerald-700 disabled:opacity-50" disabled>
          + Tambah
        </button>
      </div>
      <div class="bg-white rounded-2xl border overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b text-left text-xs uppercase text-gray-400">
                <th class="px-4 py-3">Kategori</th>
                <th class="px-4 py-3">Tanggal</th>
                <th class="px-4 py-3">Penceramah</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody id="jadwalBody"></tbody>
          </table>
        </div>
        <div id="jadwalEmpty" class="text-center py-12 text-gray-400">
          <p class="text-sm">Belum ada jadwal</p>
        </div>
      </div>
    </section>

    <!-- TAB: KEUANGAN -->
    <section class="fade-up" style="animation-delay:0.4s">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-bold uppercase text-gray-400 flex items-center gap-2">
          <i data-lucide="wallet" class="w-4 h-4"></i> Keuangan Masjid
        </h2>
        <button id="btnAddTx" class="bg-emerald-600 text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-emerald-700 disabled:opacity-50" disabled>
          + Transaksi
        </button>
      </div>
      
      <!-- Summary Cards -->
      <div class="grid grid-cols-2 gap-3 mb-4">
        <div class="bg-white rounded-xl border p-4">
          <p class="text-xs text-gray-400 uppercase font-semibold">Total Saldo</p>
          <p id="totalBalance" class="text-2xl font-extrabold text-emerald-600">Rp 0</p>
        </div>
        <div class="bg-white rounded-xl border p-4">
          <p class="text-xs text-gray-400 uppercase font-semibold">Pengeluaran Bulan Ini</p>
          <p id="monthlyExpense" class="text-2xl font-extrabold text-red-500">Rp 0</p>
        </div>
      </div>
      
      <!-- Transaction Table -->
      <div class="bg-white rounded-2xl border overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b text-left text-xs uppercase text-gray-400">
                <th class="px-4 py-3">Tanggal</th>
                <th class="px-4 py-3">Keterangan</th>
                <th class="px-4 py-3 text-right">Jumlah</th>
                <th class="px-4 py-3 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody id="txBody"></tbody>
          </table>
        </div>
        <div id="txEmpty" class="text-center py-12 text-gray-400">
          <p class="text-sm">Belum ada transaksi</p>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="text-center py-6 text-xs text-gray-400">
    Masjid Digital Display • Powered by Firebase
  </footer>

  <!-- ADMIN MODAL -->
  <div id="adminModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; display:none; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:24px; max-width:360px; width:90%;">
      <h3 class="text-lg font-bold mb-4">Admin Login</h3>
      <form id="adminForm">
        <input type="password" id="adminPassword" placeholder="Password" class="w-full border rounded-lg px-3 py-2 mb-3" required>
        <div class="flex gap-2">
          <button type="button" id="adminCancel" class="flex-1 py-2 rounded-lg bg-gray-100 hover:bg-gray-200">Batal</button>
          <button type="submit" class="flex-1 py-2 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700">Login</button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL FORM -->
  <div id="formModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; display:none; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:24px; max-width:400px; width:90%; max-height:90vh; overflow-y:auto;">
      <div class="flex justify-between items-center mb-4">
        <h3 id="formModalTitle" class="text-lg font-bold"></h3>
        <button id="formModalClose" class="w-8 h-8 rounded-lg hover:bg-gray-100 flex items-center justify-center">✕</button>
      </div>
      <div id="formModalBody"></div>
    </div>
  </div>

  <!-- TOAST -->
  <div id="toast" style="position:fixed; bottom:24px; left:50%; transform:translateX(-50%); background:#1f2937; color:white; padding:12px 24px; border-radius:12px; font-size:14px; opacity:0; transition:opacity 0.3s; z-index:200; pointer-events:none;"></div>

  <script>
    // ============================================
    // 🔥 GANTI BAGIAN INI DENGAN KONFIGURASI ANDA!
    // ============================================
    const firebaseConfig = {
      apiKey: "AIzaSyAvG7VSUNPEguqXkU1uCMPrTgqlDvBEwIM",
      authDomain: "simmasjidtasq.firebaseapp.com",
      databaseURL: "https://simmasjidtasq-default-rtdb.firebaseio.com",
      projectId: "simmasjidtasq",
      storageBucket: "simmasjidtasq.firebasestorage.app",
      messagingSenderId: "769075970481",
      appId: "1:769075970481:web:bf87bf2088f2c2c059fd90",
      measurementId: "G-SKCSX4ZYQ6"
    };
    
    // Initialize Firebase
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
    
    console.log('✅ Firebase connected!');

    // ============================================
    // STATE
    // ============================================
    let prayers = [
      { id: 'subuh', name: 'Subuh', time: '04:35' },
      { id: 'dzuhur', name: 'Dzuhur', time: '12:05' },
      { id: 'ashar', name: 'Ashar', time: '15:20' },
      { id: 'maghrib', name: 'Maghrib', time: '18:05' },
      { id: 'isya', name: 'Isya', time: '19:15' }
    ];
    
    let jadwalList = [];
    let txList = [];
    let isAdmin = false;
    let editData = null;

    // ============================================
    // REAL-TIME LISTENERS
    // ============================================
    function setupListeners() {
      // Listen Jadwal
      db.collection('jadwal').orderBy('date', 'asc').onSnapshot(snapshot => {
        jadwalList = [];
        snapshot.forEach(doc => {
          jadwalList.push({ id: doc.id, ...doc.data() });
        });
        renderJadwal();
      });

      // Listen Transaksi
      db.collection('transactions').orderBy('created_at', 'desc').onSnapshot(snapshot => {
        txList = [];
        snapshot.forEach(doc => {
          txList.push({ id: doc.id, ...doc.data() });
        });
        renderKeuangan();
      });

      // Listen Prayers
      db.collection('prayers').onSnapshot(snapshot => {
        const data = [];
        snapshot.forEach(doc => data.push({ id: doc.id, ...doc.data() }));
        if (data.length > 0) {
          prayers = prayers.map(p => {
            const found = data.find(d => d.id === p.id);
            return found ? { ...p, time: found.time } : p;
          });
        }
        renderPrayerGrid();
        updateClock();
      });
    }

    // ============================================
    // RENDER FUNCTIONS
    // ============================================
    function renderPrayerGrid() {
      const grid = document.getElementById('prayerGrid');
      grid.innerHTML = prayers.map(p => `
        <div class="bg-white rounded-xl border p-3 text-center">
          <p class="text-xs font-semibold text-gray-400 uppercase">${p.name}</p>
          <p class="text-lg font-extrabold">${p.time}</p>
        </div>
      `).join('');
    }

    function renderJadwal() {
      const body = document.getElementById('jadwalBody');
      const empty = document.getElementById('jadwalEmpty');
      
      if (jadwalList.length === 0) {
        body.innerHTML = '';
        empty.style.display = 'block';
        return;
      }
      
      empty.style.display = 'none';
      
      body.innerHTML = jadwalList.map(item => {
        const statusColor = item.status === 'Selesai' ? 'bg-emerald-100 text-emerald-700'
          : item.status === 'Tidak Ada' ? 'bg-gray-100 text-gray-600'
          : 'bg-blue-100 text-blue-700';
        
        return `
          <tr class="border-b hover:bg-gray-50">
            <td class="px-4 py-3 font-medium">${item.category}</td>
            <td class="px-4 py-3 text-gray-500">${item.date}</td>
            <td class="px-4 py-3">${item.speaker}</td>
            <td class="px-4 py-3">
              <span class="text-xs font-semibold px-2 py-1 rounded-full ${statusColor}">${item.status}</span>
            </td>
            <td class="px-4 py-3 text-right">
              <button onclick="editJadwal('${item.id}')" class="text-gray-400 hover:text-emerald-600 mr-2" ${isAdmin ? '' : 'disabled'}>✏️</button>
              <button onclick="deleteJadwal('${item.id}')" class="text-gray-400 hover:text-red-500" ${isAdmin ? '' : 'disabled'}>🗑️</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function renderKeuangan() {
      const body = document.getElementById('txBody');
      const empty = document.getElementById('txEmpty');
      
      if (txList.length === 0) {
        body.innerHTML = '';
        empty.style.display = 'block';
        document.getElementById('totalBalance').textContent = 'Rp 0';
        document.getElementById('monthlyExpense').textContent = 'Rp 0';
        return;
      }
      
      empty.style.display = 'none';
      
      let balance = 0;
      let monthlyExp = 0;
      const thisMonth = new Date().toISOString().substring(0, 7);
      
      txList.forEach(t => {
        if (t.tx_type === 'Pemasukan') balance += t.amount;
        else {
          balance -= t.amount;
          if (t.date && t.date.startsWith(thisMonth)) monthlyExp += t.amount;
        }
      });
      
      document.getElementById('totalBalance').textContent = 'Rp ' + balance.toLocaleString('id-ID');
      document.getElementById('monthlyExpense').textContent = 'Rp ' + monthlyExp.toLocaleString('id-ID');
      
      body.innerHTML = txList.map(t => {
        const isIn = t.tx_type === 'Pemasukan';
        return `
          <tr class="border-b hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500 text-xs">${t.date || '-'}</td>
            <td class="px-4 py-3 font-medium">${t.description}</td>
            <td class="px-4 py-3 text-right font-semibold ${isIn ? 'text-emerald-600' : 'text-red-500'}">
              ${isIn ? '+' : '-'} Rp ${t.amount.toLocaleString('id-ID')}
            </td>
            <td class="px-4 py-3 text-right">
              <button onclick="editTx('${t.id}')" class="text-gray-400 hover:text-emerald-600 mr-2" ${isAdmin ? '' : 'disabled'}>✏️</button>
              <button onclick="deleteTx('${t.id}')" class="text-gray-400 hover:text-red-500" ${isAdmin ? '' : 'disabled'}>🗑️</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    // ============================================
    // CLOCK & COUNTDOWN
    // ============================================
    function updateClock() {
      const now = new Date();
      document.getElementById('clockDisplay').textContent = 
        now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      
      document.getElementById('currentDate').textContent = 
        now.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      
      document.getElementById('heroDate').textContent = 
        now.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      
      // Countdown
      const nowMin = now.getHours() * 60 + now.getMinutes();
      let next = null;
      
      for (const p of prayers) {
        const [h, m] = p.time.split(':').map(Number);
        if (h * 60 + m > nowMin) { next = p; break; }
      }
      if (!next) next = prayers[0];
      
      document.getElementById('nextPrayer').textContent = next.name;
      
      const [nh, nm] = next.time.split(':').map(Number);
      let diffSec = (nh * 60 + nm) * 60 - (now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds());
      if (diffSec < 0) diffSec += 86400;
      
      const h = String(Math.floor(diffSec / 3600)).padStart(2, '0');
      const m = String(Math.floor((diffSec % 3600) / 60)).padStart(2, '0');
      const s = String(diffSec % 60).padStart(2, '0');
      
      document.getElementById('countdownDisplay').textContent = `${h}:${m}:${s}`;
    }

    // ============================================
    // CRUD OPERATIONS
    // ============================================
    async function addJadwal(data) {
      await db.collection('jadwal').add({
        ...data,
        created_at: firebase.firestore.FieldValue.serverTimestamp()
      });
    }

    async function updateJadwal(id, data) {
      await db.collection('jadwal').doc(id).update(data);
    }

    async function deleteJadwal(id) {
      await db.collection('jadwal').doc(id).delete();
    }

    async function addTransaction(data) {
      await db.collection('transactions').add({
        ...data,
        created_at: firebase.firestore.FieldValue.serverTimestamp()
      });
    }

    async function updateTransaction(id, data) {
      await db.collection('transactions').doc(id).update(data);
    }

    async function deleteTransaction(id) {
      await db.collection('transactions').doc(id).delete();
    }

    // ============================================
    // GLOBAL FUNCTIONS
    // ============================================
    window.editJadwal = function(id) {
      if (!isAdmin) return;
      const item = jadwalList.find(j => j.id === id);
      if (!item) return;
      editData = item;
      showJadwalForm(item);
    };

    window.deleteJadwal = async function(id) {
      if (!isAdmin) return;
      if (confirm('Hapus jadwal ini?')) {
        await deleteJadwal(id);
        showToast('Jadwal dihapus');
      }
    };

    window.editTx = function(id) {
      if (!isAdmin) return;
      const item = txList.find(t => t.id === id);
      if (!item) return;
      editData = item;
      showTxForm(item);
    };

    window.deleteTx = async function(id) {
      if (!isAdmin) return;
      if (confirm('Hapus transaksi ini?')) {
        await deleteTransaction(id);
        showToast('Transaksi dihapus');
      }
    };

    // ============================================
    // FORM MODALS
    // ============================================
    function showJadwalForm(data = null) {
      document.getElementById('formModalTitle').textContent = data ? 'Edit Jadwal' : 'Tambah Jadwal';
      document.getElementById('formModalBody').innerHTML = `
        <form id="jadwalForm" class="space-y-3">
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Kategori</label>
            <select id="jCat" class="w-full border rounded-lg px-3 py-2">
              <option ${data?.category === 'Khutbah Jumat' ? 'selected' : ''}>Khutbah Jumat</option>
              <option ${data?.category === 'Kajian Rutin' ? 'selected' : ''}>Kajian Rutin</option>
              <option ${data?.category === 'Tabligh Akbar' ? 'selected' : ''}>Tabligh Akbar</option>
              <option ${data?.category === 'Pengajian Ibu-ibu' ? 'selected' : ''}>Pengajian Ibu-ibu</option>
              <option ${data?.category === 'Kultum' ? 'selected' : ''}>Kultum</option>
              <option ${data?.category === 'Lainnya' ? 'selected' : ''}>Lainnya</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Tanggal</label>
            <input type="date" id="jDate" value="${data?.date || ''}" class="w-full border rounded-lg px-3 py-2" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Penceramah</label>
            <input type="text" id="jSpeaker" value="${data?.speaker || ''}" placeholder="Nama Ustadz" class="w-full border rounded-lg px-3 py-2" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Status</label>
            <select id="jStatus" class="w-full border rounded-lg px-3 py-2">
              <option ${data?.status === 'Terjadwal' ? 'selected' : ''}>Terjadwal</option>
              <option ${data?.status === 'Selesai' ? 'selected' : ''}>Selesai</option>
              <option ${data?.status === 'Tidak Ada' ? 'selected' : ''}>Tidak Ada</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-emerald-600 text-white py-2 rounded-lg hover:bg-emerald-700">
            ${data ? 'Simpan' : 'Tambah'}
          </button>
        </form>
      `;
      
      document.getElementById('formModal').style.display = 'flex';
      
      document.getElementById('jadwalForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = {
          category: document.getElementById('jCat').value,
          date: document.getElementById('jDate').value,
          speaker: document.getElementById('jSpeaker').value,
          status: document.getElementById('jStatus').value
        };
        
        if (editData) {
          await updateJadwal(editData.id, formData);
          showToast('Jadwal diperbarui');
        } else {
          await addJadwal(formData);
          showToast('Jadwal ditambahkan');
        }
        
        closeFormModal();
      });
    }

    function showTxForm(data = null) {
      document.getElementById('formModalTitle').textContent = data ? 'Edit Transaksi' : 'Tambah Transaksi';
      document.getElementById('formModalBody').innerHTML = `
        <form id="txForm" class="space-y-3">
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Tanggal</label>
            <input type="date" id="txDate" value="${data?.date || new Date().toISOString().split('T')[0]}" class="w-full border rounded-lg px-3 py-2" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Tipe</label>
            <select id="txType" class="w-full border rounded-lg px-3 py-2">
              <option ${data?.tx_type === 'Pemasukan' ? 'selected' : ''}>Pemasukan</option>
              <option ${data?.tx_type === 'Pengeluaran' ? 'selected' : ''}>Pengeluaran</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Keterangan</label>
            <input type="text" id="txDesc" value="${data?.description || ''}" placeholder="Infaq Jumat" class="w-full border rounded-lg px-3 py-2" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Jumlah (Rp)</label>
            <input type="number" id="txAmt" value="${data?.amount || ''}" placeholder="500000" class="w-full border rounded-lg px-3 py-2" required>
          </div>
          <button type="submit" class="w-full bg-emerald-600 text-white py-2 rounded-lg hover:bg-emerald-700">
            ${data ? 'Simpan' : 'Tambah'}
          </button>
        </form>
      `;
      
      document.getElementById('formModal').style.display = 'flex';
      
      document.getElementById('txForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = {
          date: document.getElementById('txDate').value,
          tx_type: document.getElementById('txType').value,
          description: document.getElementById('txDesc').value,
          amount: Number(document.getElementById('txAmt').value)
        };
        
        if (editData) {
          await updateTransaction(editData.id, formData);
          showToast('Transaksi diperbarui');
        } else {
          await addTransaction(formData);
          showToast('Transaksi ditambahkan');
        }
        
        closeFormModal();
      });
    }

    function closeFormModal() {
      document.getElementById('formModal').style.display = 'none';
      editData = null;
    }

    // ============================================
    // TOAST
    // ============================================
    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.style.opacity = '1';
      setTimeout(() => {
        toast.style.opacity = '0';
      }, 2000);
    }

    // ============================================
    // ADMIN MODE
    // ============================================
    document.getElementById('adminBtn').addEventListener('click', () => {
      if (isAdmin) {
        isAdmin = false;
        updateAdminUI();
        showToast('Admin mode dimatikan');
      } else {
        document.getElementById('adminModal').style.display = 'flex';
        document.getElementById('adminPassword').focus();
      }
    });

    document.getElementById('adminCancel').addEventListener('click', () => {
      document.getElementById('adminModal').style.display = 'none';
    });

    document.getElementById('adminForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const pwd = document.getElementById('adminPassword').value;
      if (pwd === 'masjid123') {
        isAdmin = true;
        document.getElementById('adminModal').style.display = 'none';
        document.getElementById('adminPassword').value = '';
        updateAdminUI();
        showToast('Admin mode diaktifkan');
      } else {
        showToast('Password salah!');
      }
    });

    function updateAdminUI() {
      const buttons = ['btnAddJadwal', 'btnAddTx'];
      buttons.forEach(id => {
        document.getElementById(id).disabled = !isAdmin;
        document.getElementById(id).style.opacity = isAdmin ? '1' : '0.5';
      });
      renderJadwal();
      renderKeuangan();
    }

    // ============================================
    // FORM MODAL CLOSE
    // ============================================
    document.getElementById('formModalClose').addEventListener('click', closeFormModal);
    document.getElementById('formModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeFormModal();
    });

    // ============================================
    // BUTTON HANDLERS
    // ============================================
    document.getElementById('btnAddJadwal').addEventListener('click', () => {
      editData = null;
      showJadwalForm();
    });

    document.getElementById('btnAddTx').addEventListener('click', () => {
      editData = null;
      showTxForm();
    });

    // ============================================
    // INIT
    // ============================================
    setupListeners();
    renderPrayerGrid();
    updateClock();
    setInterval(updateClock, 1000);
    
    // Initialize Lucide icons
    lucide.createIcons();
    
    console.log('🚀 App ready!');
  </script>
</body>
</html>
